{
  "info": {
    "name": "Simplify Money Platform - Complete API Collection",
    "description": "Comprehensive API testing collection for the Simplify Money Platform with 3 microservices",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Simplify Money Service",
      "item": [
        {
          "name": "1. Purchase Gold",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Idempotency-Key", "value": "{{$randomUUID}}"},
              {"key": "X-Correlation-ID", "value": "{{$randomUUID}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user-{{$randomInt}}\",\n  \"amount\": 100.50,\n  \"paymentMethod\": \"UPI\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/gold/purchase",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "gold", "purchase"]
            },
            "description": "Initiate a gold purchase transaction. Returns transaction ID and state."
          }
        },
        {
          "name": "2. Get Portfolio by UserId",
          "request": {
            "method": "GET",
            "header": [
              {"key": "X-Correlation-ID", "value": "{{$randomUUID}}"}
            ],
            "url": {
              "raw": "http://localhost:8080/api/v1/portfolio/user-1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "portfolio", "user-1"]
            },
            "description": "Get the portfolio details for a specific user including total investment and gold grams."
          }
        },
        {
          "name": "3. Get User Transactions",
          "request": {
            "method": "GET",
            "header": [
              {"key": "X-Correlation-ID", "value": "{{$randomUUID}}"}
            ],
            "url": {
              "raw": "http://localhost:8080/api/v1/transactions/user-1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "transactions", "user-1"]
            },
            "description": "Get all transactions for a specific user ordered by creation date (newest first)."
          }
        },
        {
          "name": "4. Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/actuator/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["actuator", "health"]
            },
            "description": "Check the health status of the Simplify Money Service."
          }
        },
        {
          "name": "5. Metrics",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/actuator/metrics",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["actuator", "metrics"]
            },
            "description": "Get available metrics for the service."
          }
        }
      ]
    },
    {
      "name": "Payment Gateway Service",
      "item": [
        {
          "name": "1. Get Payment Methods",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8081/api/v1/payment-methods",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["api", "v1", "payment-methods"]
            },
            "description": "Get a list of available payment methods (UPI, NET_BANKING, CARD)."
          }
        },
        {
          "name": "2. Process Payment",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100.50,\n  \"method\": \"UPI\",\n  \"userId\": \"user-1\"\n}"
            },
            "url": {
              "raw": "http://localhost:8081/api/v1/pay",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["api", "v1", "pay"]
            },
            "description": "Process a payment. Success rate is configured (default 80%). Returns transaction ID and status."
          }
        },
        {
          "name": "3. Check Payment Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8081/api/v1/payment-status/txn-123",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["api", "v1", "payment-status", "txn-123"]
            },
            "description": "Check the status of a specific payment transaction by transaction ID."
          }
        },
        {
          "name": "4. Process Refund",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"txnId\": \"txn-123\",\n  \"amount\": 50.25\n}"
            },
            "url": {
              "raw": "http://localhost:8081/api/v1/refund",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["api", "v1", "refund"]
            },
            "description": "Process a refund for a payment transaction."
          }
        }
      ]
    },
    {
      "name": "Gold Partner Service",
      "item": [
        {
          "name": "1. Get Current Gold Rate",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8082/api/v1/gold-rate",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["api", "v1", "gold-rate"]
            },
            "description": "Get the current price per gram of gold with slight fluctuation (95-105% of base price). Base price: Rs. 6000."
          }
        },
        {
          "name": "2. Allocate Gold",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"txnId\": \"txn-123\",\n  \"userId\": \"user-1\",\n  \"amount\": 100.50,\n  \"pricePerGram\": 5700.00\n}"
            },
            "url": {
              "raw": "http://localhost:8082/api/v1/allot-gold",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["api", "v1", "allot-gold"]
            },
            "description": "Allocate gold grams to a user. Success rate: 90% (10% failure rate). Calculates grams = amount / pricePerGram."
          }
        }
      ]
    },
    {
      "name": "Prometheus Monitoring",
      "item": [
        {
          "name": "1. Prometheus Metrics",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:9090/metrics",
              "protocol": "http",
              "host": ["localhost"],
              "port": "9090",
              "path": ["metrics"]
            },
            "description": "Get Prometheus metrics in text format."
          }
        },
        {
          "name": "2. Simplify Money Metrics",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/actuator/prometheus",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["actuator", "prometheus"]
            },
            "description": "Get Prometheus metrics from the Simplify Money Service."
          }
        },
        {
          "name": "3. Prometheus UI",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:9090",
              "protocol": "http",
              "host": ["localhost"],
              "port": "9090",
              "path": []
            },
            "description": "Access the Prometheus UI (open in browser)."
          }
        }
      ]
    },
    {
      "name": "Integration Tests",
      "item": [
        {
          "name": "Complete Purchase Flow - Test 1",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Idempotency-Key", "value": "flow-test-{{$timestamp}}"},
              {"key": "X-Correlation-ID", "value": "corr-{{$randomUUID}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"integration-test-user\",\n  \"amount\": 500.00,\n  \"paymentMethod\": \"NET_BANKING\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/gold/purchase",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "gold", "purchase"]
            },
            "description": "Execute a complete purchase flow through the orchestration service. This will:\n1. Get gold rate\n2. Process payment\n3. Allocate gold\n4. Update portfolio"
          }
        },
        {
          "name": "Stress Test - Rapid Purchases",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Idempotency-Key", "value": "stress-{{$timestamp}}"},
              {"key": "X-Correlation-ID", "value": "stress-{{$randomUUID}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"stress-test-user-{{$randomInt}}\",\n  \"amount\": 50.00,\n  \"paymentMethod\": \"UPI\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/gold/purchase",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "gold", "purchase"]
            },
            "description": "Run this multiple times rapidly to test system performance and logging under load."
          }
        },
        {
          "name": "Check Stress Test Results",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/v1/transactions/stress-test-user-1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "transactions", "stress-test-user-1"]
            },
            "description": "Check all transactions created by the stress test."
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url_simplify",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "base_url_payment",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "base_url_gold",
      "value": "http://localhost:8082",
      "type": "string"
    },
    {
      "key": "base_url_prometheus",
      "value": "http://localhost:9090",
      "type": "string"
    },
    {
      "key": "correlation_id",
      "value": "{{$randomUUID}}",
      "type": "string"
    }
  ]
}
